CREATE TABLE messages (
    update_id INTEGER PRIMARY KEY,
    session TEXT NOT NULL,
    type TEXT NOT NULL,
    message TEXT NOT NULL,
    status TEXT,
    tool_name TEXT,
    command TEXT,
    file_path TEXT,
    timestamp INTEGER NOT NULL,
    is_from_relay INTEGER NOT NULL DEFAULT 0,
    callback_response TEXT
);

insertOrIgnore:
INSERT OR IGNORE INTO messages (update_id, session, type, message, status, tool_name, command, file_path, timestamp, is_from_relay, callback_response)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getMessagesForSession:
SELECT * FROM messages WHERE session = ? ORDER BY timestamp ASC;

getRecentMessages:
SELECT * FROM messages ORDER BY timestamp DESC LIMIT 50;

getLastMessageForSession:
SELECT * FROM messages WHERE session = ? ORDER BY timestamp DESC LIMIT 1;

insertOutgoing:
INSERT INTO messages (update_id, session, type, message, status, tool_name, command, file_path, timestamp, is_from_relay)
VALUES (?, ?, 'TEXT', ?, NULL, NULL, NULL, NULL, ?, 1);

countOutgoingForSession:
SELECT COUNT(*) FROM messages WHERE session = ? AND is_from_relay = 1;

markAnswered:
UPDATE messages SET callback_response = ? WHERE update_id = ?;
